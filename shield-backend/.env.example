PORT=5001
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shield_auth
DB_USER=fatalerror
DB_PASS=CHANGE_ME_DATABASE_PASSWORD
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
NODE_ENV=production
CORS_ORIGIN=https://sosiskibot.ru,https://www.sosiskibot.ru
TRUST_PROXY=1
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
AUTH_CODE_TTL_MINUTES=15
PASSWORD_RESET_TTL_MINUTES=30
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailbox@example.com
SMTP_PASS=replace_with_app_password
MAIL_FROM=ShieldSecurity <your_mailbox@example.com>
APP_RESET_URL=shieldsecurity://auth/reset-password
