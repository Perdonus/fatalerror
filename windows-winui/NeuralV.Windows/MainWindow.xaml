<Window
    x:Class="NeuralV.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NeuralV">

    <Grid x:Name="WindowRoot" Background="{ThemeResource AppBackgroundBrush}" Loaded="OnRootLoaded">
        <Grid.Resources>
            <DataTemplate x:Key="TimelineItemTemplate">
                <Border
                    Background="{ThemeResource AppSurfaceBrush}"
                    BorderBrush="{ThemeResource AppOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="14"
                    Margin="0,0,0,10">
                    <TextBlock Text="{Binding}" Foreground="{ThemeResource AppTextBrush}" TextWrapping="Wrap" />
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="HistoryItemTemplate">
                <Border
                    Background="{ThemeResource AppSurfaceBrush}"
                    BorderBrush="{ThemeResource AppOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="14"
                    Margin="0,0,0,10">
                    <TextBlock Text="{Binding}" Foreground="{ThemeResource AppTextBrush}" TextWrapping="Wrap" />
                </Border>
            </DataTemplate>
        </Grid.Resources>

        <Grid>
            <Rectangle x:Name="BackdropGradient" />
            <Rectangle x:Name="FabricLayerA" Width="1800" Height="920" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-280,-180,0,0" Opacity="0.18" />
            <Rectangle x:Name="FabricLayerB" Width="1700" Height="960" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-220,0" Opacity="0.14" />
            <Rectangle x:Name="FabricLayerC" Width="1650" Height="940" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-260" Opacity="0.10" />
            <Ellipse x:Name="GlowA" Width="560" Height="560" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-120,-80,0,0" Opacity="0.28" />
            <Ellipse x:Name="GlowB" Width="700" Height="700" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-180,-180" Opacity="0.22" />
            <Ellipse x:Name="GlowC" Width="460" Height="460" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-150" Opacity="0.16" />
        </Grid>

        <Grid x:Name="ShellFrame" Padding="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="RailColumn" Width="320" />
                <ColumnDefinition x:Name="GutterColumn" Width="20" />
                <ColumnDefinition x:Name="ContentColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="RailPanel"
                Grid.Column="0"
                Background="{ThemeResource AppSurfaceStrongBrush}"
                BorderBrush="{ThemeResource AppOutlineBrush}"
                BorderThickness="1"
                CornerRadius="28"
                Padding="20">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="64"
                                Height="64"
                                CornerRadius="18"
                                Background="{ThemeResource AppSurfaceHighBrush}"
                                BorderBrush="{ThemeResource AppOutlineBrush}"
                                BorderThickness="1"
                                Margin="0,0,12,0">
                                <Image Source="ms-appx:///Assets/NeuralV.png" Stretch="Uniform" Margin="12" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="NeuralV" Foreground="{ThemeResource AppTextBrush}" FontSize="28" FontWeight="SemiBold" />
                                <TextBlock Text="Windows-клиент" Foreground="{ThemeResource AppMutedTextBrush}" />
                            </StackPanel>
                        </Grid>

                        <Border
                            Background="{ThemeResource AppSecondaryContainerBrush}"
                            BorderBrush="{ThemeResource AppOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12">
                            <TextBlock x:Name="RailBadgeText" Foreground="{ThemeResource AppTextBrush}" />
                        </Border>

                        <TextBlock
                            x:Name="RailHeadlineText"
                            Foreground="{ThemeResource AppTextBrush}"
                            FontSize="30"
                            FontWeight="SemiBold"
                            TextWrapping="Wrap"
                            Margin="0,0,0,8" />
                        <TextBlock
                            x:Name="RailDescriptionText"
                            Foreground="{ThemeResource AppMutedTextBrush}"
                            TextWrapping="Wrap"
                            Margin="0,0,0,18" />

                        <Border
                            Background="{ThemeResource AppSurfaceBrush}"
                            BorderBrush="{ThemeResource AppOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="22"
                            Padding="18"
                            Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Палитра" Foreground="{ThemeResource AppTextBrush}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock x:Name="PaletteSourceLabel" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border x:Name="PaletteSwatchPrimary" Width="48" Height="48" CornerRadius="14" Margin="0,0,10,0" />
                                    <Border x:Name="PaletteSwatchSecondary" Width="48" Height="48" CornerRadius="14" Margin="0,0,10,0" />
                                    <Border x:Name="PaletteSwatchTertiary" Width="48" Height="48" CornerRadius="14" />
                                </StackPanel>
                                <TextBlock x:Name="PaletteSeedLabel" Foreground="{ThemeResource AppSubtleTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border
                            Background="{ThemeResource AppSurfaceBrush}"
                            BorderBrush="{ThemeResource AppOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="22"
                            Padding="18">
                            <StackPanel>
                                <TextBlock Text="Аккаунт" Foreground="{ThemeResource AppTextBrush}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <TextBlock x:Name="RailUserNameText" Foreground="{ThemeResource AppTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBlock x:Name="RailUserMetaText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                <Border
                                    Background="{ThemeResource AppSecondaryContainerBrush}"
                                    BorderBrush="{ThemeResource AppOutlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="10,6"
                                    HorizontalAlignment="Left">
                                    <TextBlock x:Name="RailUserStateText" Foreground="{ThemeResource AppTextBrush}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid x:Name="ContentShell" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="HeaderMetaBar" Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{ThemeResource AppSecondaryContainerBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="14" Padding="12,8" Margin="0,0,12,0">
                        <TextBlock x:Name="ThemeModeLabel" Foreground="{ThemeResource AppTextBrush}" />
                    </Border>
                    <Border Grid.Column="1" Background="{ThemeResource AppSecondaryContainerBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="14" Padding="12,8" Margin="0,0,12,0">
                        <TextBlock x:Name="PaletteModeHeaderLabel" Foreground="{ThemeResource AppTextBrush}" />
                    </Border>
                    <Border Grid.Column="3" Background="{ThemeResource AppSecondaryContainerBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="14" Padding="12,8">
                        <TextBlock x:Name="VersionLabel" Foreground="{ThemeResource AppTextBrush}" />
                    </Border>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource AppSurfaceStrongBrush}"
                    BorderBrush="{ThemeResource AppOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="28"
                    Padding="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="AppNavigationBar" Grid.Row="0" Visibility="Collapsed" Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="HomeNavButton" Content="Обзор" Click="OnHomeClick" Margin="0,0,10,0" />
                                <Button x:Name="HistoryNavButton" Content="История" Click="OnHistoryClick" Margin="0,0,10,0" />
                                <Button x:Name="SettingsNavButton" Content="Настройки" Click="OnSettingsClick" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{ThemeResource AppSecondaryContainerBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="14" Padding="12,8">
                                <TextBlock x:Name="UserLabel" Foreground="{ThemeResource AppTextBrush}" />
                            </Border>
                        </Grid>

                        <Border x:Name="StatusBanner" Grid.Row="1" Visibility="Collapsed" Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,16">
                            <TextBlock x:Name="StatusBannerText" Foreground="{ThemeResource AppTextBrush}" TextWrapping="Wrap" />
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid x:Name="SplashView">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="540">
                                    <Grid Width="132" Height="132" HorizontalAlignment="Center" Margin="0,0,0,18">
                                        <Border x:Name="SplashHalo" Width="132" Height="132" CornerRadius="66" Background="{ThemeResource AppAccentSoftBrush}" />
                                        <Ellipse x:Name="SplashOrbitRing" Width="112" Height="112" Stroke="{ThemeResource AppAccentBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Border Width="84" Height="84" CornerRadius="24" Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Source="ms-appx:///Assets/NeuralV.png" Stretch="Uniform" Margin="14" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Запускаем NeuralV" Foreground="{ThemeResource AppTextBrush}" FontSize="34" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,10" />
                                    <TextBlock Text="Поднимаем палитру, сессию и основной экран." Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <ScrollViewer x:Name="WelcomeView" Visibility="Collapsed">
                                <StackPanel MaxWidth="880">
                                    <TextBlock Text="NeuralV для Windows" Foreground="{ThemeResource AppTextBrush}" FontSize="36" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <TextBlock Text="Нативный клиент для входа, проверки, истории и обновления." Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Войти в аккаунт" Click="OnShowLoginClick" Margin="0,0,12,0" />
                                        <Button Content="Создать аккаунт" Click="OnShowRegisterClick" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <ScrollViewer x:Name="LoginView" Visibility="Collapsed">
                                <StackPanel MaxWidth="760">
                                    <TextBlock Text="Вход" Foreground="{ThemeResource AppTextBrush}" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <TextBlock Text="Введи почту и пароль. Потом придёт код подтверждения." Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                    <TextBlock Text="E-mail" Foreground="{ThemeResource AppMutedTextBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="LoginEmailBox" PlaceholderText="name@example.com" Margin="0,0,0,12" />
                                    <TextBlock Text="Пароль" Foreground="{ThemeResource AppMutedTextBrush}" Margin="0,0,0,6" />
                                    <PasswordBox x:Name="LoginPasswordBox" Margin="0,0,0,18" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Назад" Click="OnBackToWelcomeClick" Margin="0,0,12,0" />
                                        <Button Content="Продолжить" Click="OnStartLoginClick" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <ScrollViewer x:Name="RegisterView" Visibility="Collapsed">
                                <StackPanel MaxWidth="760">
                                    <TextBlock Text="Регистрация" Foreground="{ThemeResource AppTextBrush}" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <TextBlock Text="Создай аккаунт и подтверди почту кодом." Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                    <TextBlock Text="Имя" Foreground="{ThemeResource AppMutedTextBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="RegisterNameBox" Margin="0,0,0,12" />
                                    <TextBlock Text="E-mail" Foreground="{ThemeResource AppMutedTextBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="RegisterEmailBox" PlaceholderText="name@example.com" Margin="0,0,0,12" />
                                    <TextBlock Text="Пароль" Foreground="{ThemeResource AppMutedTextBrush}" Margin="0,0,0,6" />
                                    <PasswordBox x:Name="RegisterPasswordBox" Margin="0,0,0,12" />
                                    <TextBlock Text="Повтори пароль" Foreground="{ThemeResource AppMutedTextBrush}" Margin="0,0,0,6" />
                                    <PasswordBox x:Name="RegisterPasswordRepeatBox" Margin="0,0,0,18" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Назад" Click="OnBackToWelcomeClick" Margin="0,0,12,0" />
                                        <Button Content="Создать аккаунт" Click="OnStartRegisterClick" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <ScrollViewer x:Name="CodeView" Visibility="Collapsed">
                                <StackPanel MaxWidth="760">
                                    <TextBlock Text="Подтверждение" Foreground="{ThemeResource AppTextBrush}" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <TextBlock x:Name="CodeHintText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                    <TextBlock Text="Код" Foreground="{ThemeResource AppMutedTextBrush}" Margin="0,0,0,6" />
                                    <TextBox x:Name="VerificationCodeBox" PlaceholderText="123456" Margin="0,0,0,18" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Назад" Click="OnBackFromCodeClick" Margin="0,0,12,0" />
                                        <Button Content="Войти" Click="OnVerifyCodeClick" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <ScrollViewer x:Name="HomeView" Visibility="Collapsed">
                                <StackPanel MaxWidth="960">
                                    <TextBlock Text="Панель проверки" Foreground="{ThemeResource AppTextBrush}" FontSize="34" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <TextBlock x:Name="HomeStatusText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                        <Button x:Name="QuickScanButton" Content="Быстрая проверка" Click="OnQuickScanClick" Margin="0,0,12,0" />
                                        <Button x:Name="DeepScanButton" Content="Глубокая проверка" Click="OnDeepScanClick" />
                                    </StackPanel>
                                    <Border Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Обновления" Foreground="{ThemeResource AppTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <TextBlock x:Name="UpdateStatusText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                            <Button x:Name="UpdateButton" Content="Скачать обновление" Click="OnDownloadUpdateClick" Visibility="Collapsed" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="18" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="Последние события" Foreground="{ThemeResource AppTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <ListView x:Name="HomeTimelineList" ItemTemplate="{StaticResource TimelineItemTemplate}" SelectionMode="None" BorderThickness="0" Background="Transparent" MinHeight="340" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <ScrollViewer x:Name="ScanView" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="330" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="18" Padding="18">
                                        <StackPanel>
                                            <Border Width="96" Height="96" CornerRadius="48" Background="{ThemeResource AppAccentSoftBrush}" HorizontalAlignment="Left" Margin="0,0,0,18">
                                                <Grid>
                                                    <Ellipse Width="72" Height="72" Stroke="{ThemeResource AppAccentBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Text="NV" Foreground="{ThemeResource AppTextBrush}" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                            <TextBlock x:Name="ScanPrimaryText" Foreground="{ThemeResource AppTextBrush}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10" TextWrapping="Wrap" />
                                            <TextBlock x:Name="ScanSecondaryText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                            <Button Content="Отменить проверку" Click="OnCancelScanClick" Margin="0,0,0,10" />
                                            <Button Content="Назад" Click="OnBackToHomeClick" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="18" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Что происходит сейчас" Foreground="{ThemeResource AppTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <ListView x:Name="ScanTimelineList" ItemTemplate="{StaticResource TimelineItemTemplate}" SelectionMode="None" BorderThickness="0" Background="Transparent" MinHeight="440" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </ScrollViewer>

                            <ScrollViewer x:Name="HistoryView" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="История" Foreground="{ThemeResource AppTextBrush}" FontSize="34" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <TextBlock Text="Последние завершённые проверки сохраняются локально." Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,18" />
                                    <ListView x:Name="HistoryList" ItemTemplate="{StaticResource HistoryItemTemplate}" SelectionMode="None" BorderThickness="0" Background="Transparent" />
                                </StackPanel>
                            </ScrollViewer>

                            <ScrollViewer x:Name="SettingsView" Visibility="Collapsed">
                                <StackPanel MaxWidth="760">
                                    <TextBlock Text="Настройки" Foreground="{ThemeResource AppTextBrush}" FontSize="34" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <Border Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Визуальная система" Foreground="{ThemeResource AppTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <TextBlock x:Name="SettingsPaletteText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                            <TextBlock x:Name="SettingsVersionText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineBrush}" BorderThickness="1" CornerRadius="18" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Сессия" Foreground="{ThemeResource AppTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <TextBlock x:Name="SettingsSessionText" Foreground="{ThemeResource AppMutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                            <Button Content="Выйти из аккаунта" Click="OnLogoutClick" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Border x:Name="BusyOverlay" Grid.RowSpan="3" Background="{ThemeResource AppOverlayScrimBrush}" CornerRadius="28" Visibility="Collapsed">
                            <Grid>
                                <Border Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppOutlineStrongBrush}" BorderThickness="1" CornerRadius="18" Padding="18" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel>
                                        <Border Width="72" Height="72" CornerRadius="36" Background="{ThemeResource AppAccentSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,14">
                                            <Grid>
                                                <Ellipse Width="44" Height="44" Stroke="{ThemeResource AppAccentBrush}" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <TextBlock x:Name="BusyText" Text="Загрузка" Foreground="{ThemeResource AppTextBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
