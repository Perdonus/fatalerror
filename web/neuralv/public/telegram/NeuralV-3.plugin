GEMINI_BASE_URL = "https://generativelanguage.googleapis.com/v1beta/models/"

VERDICT_PATTERN = re.compile(r'\b(Безопасно|Осторожно|Опасно)\b', re.IGNORECASE)

VERDICT_ICONS = {
    "безопасно": "✅",
    "осторожно": "⚠️",
    "опасно":    "🚫",
}

